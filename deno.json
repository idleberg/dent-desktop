{
  "name": "@nsis/dent-desktop",
  "version": "0.1.0",
  "exports": "./main.ts",
  "private": true,
  "exclude": ["src/", "vite.config.ts"],
  "tasks": {
    "bundle": "deno run --allow-all npm:vite build",
    "build": "deno desktop --include=dist/bundle.js --output Dent main.ts",
    "dev": "deno run --allow-read --allow-net main.ts"
  },
  "imports": {
    "@codemirror/commands": "npm:@codemirror/commands@^6.10.4",
    "@codemirror/language": "npm:@codemirror/language@^6.12.4",
    "@codemirror/state": "npm:@codemirror/state@^6.7.0",
    "@codemirror/view": "npm:@codemirror/view@^6.43.5",
    "@lezer/highlight": "npm:@lezer/highlight@^1.2.3",
    "@nsis/codemirror": "npm:@nsis/codemirror@^0.13.0",
    "@nsis/dent": "npm:@nsis/dent@^0.13.0",
    "@sveltejs/vite-plugin-svelte": "npm:@sveltejs/vite-plugin-svelte@^7.1.2",
    "svelte": "npm:svelte@^5.46.4",
    "vite": "npm:vite@^8.1.0"
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "lib": ["deno.ns", "dom", "dom.iterable", "esnext"],
    "verbatimModuleSyntax": true
  },
  "desktop": {
    "app": {
      "name": "Dent",
      "identifier": "org.nsis-dev.dent"
    }
  }
}
